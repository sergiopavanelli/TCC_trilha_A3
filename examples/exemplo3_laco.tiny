// Exemplo 3 — Laço de repetição while
// TinyScript: linguagem do protótipo de compilador (A3 UNIBH 2026/1)

// Calcula a soma de 1 até 5
i = 1;
soma = 0;
limite = 5;

while (i <= limite) {
    soma = soma + i;
    i = i + 1;
}

print(soma);   // deve imprimir 15

// Fatorial de 5
n = 5;
fat = 1;
while (n > 1) {
    fat = fat * n;
    n = n - 1;
}
print(fat);    // deve imprimir 120
